  <diagram id="hybrid-schema-rag-detail" name="Hybrid Schema RAG Detail">
    <mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2000" pageHeight="1120" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Google Sans;fillColor=#f8fafc;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="2000" height="1120" as="geometry" />
        </mxCell>
        <mxCell id="title" value="Hybrid Schema RAG Detail: How Relevant Tables Are Selected" style="text;html=1;fontFamily=Google Sans;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=30;fontStyle=1;fontColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="360" y="35" width="1280" height="50" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Local retrieval over schema metadata only: no unrestricted database rows are sent to the LLM prompt" style="text;html=1;fontFamily=Google Sans;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=16;fontColor=#4b5563;" vertex="1" parent="1">
          <mxGeometry x="350" y="82" width="1300" height="30" as="geometry" />
        </mxCell>
        <mxCell id="q" value="&lt;b&gt;User Question&lt;/b&gt;&#xa;Natural-language request" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Google Sans;fontSize=14;fontColor=#111827;spacing=10;fillColor=#dbeafe;strokeColor=#3b82f6;" vertex="1" parent="1">
          <mxGeometry x="90" y="210" width="210" height="75" as="geometry" />
        </mxCell>
        <mxCell id="norm" value="&lt;b&gt;1. Normalize and Tokenize&lt;/b&gt;&#xa;Lowercase, split terms, remove noise, preserve domain words" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Google Sans;fontSize=14;fontColor=#111827;spacing=10;fillColor=#dcfce7;strokeColor=#22c55e;" vertex="1" parent="1">
          <mxGeometry x="370" y="185" width="230" height="100" as="geometry" />
        </mxCell>
        <mxCell id="syn" value="&lt;b&gt;2. Expand Domain Synonyms&lt;/b&gt;&#xa;client -&gt; customer&#xa;income/sales -&gt; revenue&#xa;doctor -&gt; provider/specialty" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Google Sans;fontSize=14;fontColor=#111827;spacing=10;fillColor=#dcfce7;strokeColor=#22c55e;" vertex="1" parent="1">
          <mxGeometry x="670" y="175" width="250" height="120" as="geometry" />
        </mxCell>
        <mxCell id="decomp" value="&lt;b&gt;3. Decompose Query Intent&lt;/b&gt;&#xa;Entities/metrics, joins, filters, dimensions, aggregations, comparisons" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Google Sans;fontSize=14;fontColor=#111827;spacing=10;fillColor=#dcfce7;strokeColor=#22c55e;" vertex="1" parent="1">
          <mxGeometry x="990" y="175" width="270" height="120" as="geometry" />
        </mxCell>
        <mxCell id="schemaCache" value="&lt;b&gt;Schema Chunk Cache&lt;/b&gt;&#xa;One chunk per table: DDL, columns, keys, FK neighbours, safe value hints" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Google Sans;fontSize=14;fontColor=#111827;spacing=10;fillColor=#ecfdf5;strokeColor=#22c55e;" vertex="1" parent="1">
          <mxGeometry x="370" y="400" width="300" height="110" as="geometry" />
        </mxCell>
        <mxCell id="signals" value="&lt;b&gt;4. Retrieval Signals&lt;/b&gt;&#xa;BM25 lexical score&#xa;Exact table/column boosts&#xa;Character similarity&#xa;Hashed local embedding similarity&#xa;Value-hint matches" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Google Sans;fontSize=14;fontColor=#111827;spacing=10;fillColor=#f0fdf4;strokeColor=#16a34a;" vertex="1" parent="1">
          <mxGeometry x="750" y="375" width="300" height="160" as="geometry" />
        </mxCell>
        <mxCell id="graph" value="&lt;b&gt;5. Graph Expansion&lt;/b&gt;&#xa;Add foreign-key neighbours needed for joins, e.g. orders -&gt; order_items -&gt; products" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Google Sans;fontSize=14;fontColor=#111827;spacing=10;fillColor=#f0fdf4;strokeColor=#16a34a;" vertex="1" parent="1">
          <mxGeometry x="1125" y="400" width="300" height="110" as="geometry" />
        </mxCell>
        <mxCell id="rank" value="&lt;b&gt;6. Rank and Deduplicate&lt;/b&gt;&#xa;Combine scores, retain top-k tables plus necessary FK neighbours" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Google Sans;fontSize=14;fontColor=#111827;spacing=10;fillColor=#fef3c7;strokeColor=#f59e0b;" vertex="1" parent="1">
          <mxGeometry x="1500" y="400" width="270" height="110" as="geometry" />
        </mxCell>
        <mxCell id="context" value="&lt;b&gt;Selected Prompt Context&lt;/b&gt;&#xa;Compact DDL, relevant table names, value hints, and relationship evidence" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Google Sans;fontSize=14;fontColor=#111827;spacing=10;fillColor=#f3e8ff;strokeColor=#9333ea;" vertex="1" parent="1">
